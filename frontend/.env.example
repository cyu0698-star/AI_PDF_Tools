# Copy to .env.local for local runs. In production, set these in the host dashboard.

# URL of the Python backend. Scheme optional (https:// is assumed if omitted).
# Local default if unset: http://127.0.0.1:8000
PYTHON_BACKEND_URL=http://127.0.0.1:8000

# Access password for the whole app. If unset, the gate is DISABLED (open access).
# Set a real value in production so testers must log in.
APP_PASSWORD=

# Optional. OCR endpoint. If unset, defaults to PYTHON_BACKEND_URL + /api/ocr.
# OCR_HTTP_URL=http://127.0.0.1:8000/api/ocr
OCR_HTTP_TIMEOUT_MS=180000
