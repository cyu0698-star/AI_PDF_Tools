# Copy to .env for local runs. In production, set these in the host dashboard.
# NEVER commit real keys.

# Anthropic Claude (used for document extraction + Claude OCR)
AI_API_KEY=sk-ant-your-key-here
AI_BASE_URL=https://api.anthropic.com
AI_MODEL=claude-sonnet-4-5

# OCR engine: openai (default, no local install) | claude | paddle (needs requirements-paddle.txt)
OCR_ENGINE=openai

# OpenAI-compatible OCR (used when OCR_ENGINE=openai)
OCR_OPENAI_BASE_URL=https://api.openai.com/v1
OCR_OPENAI_API_KEY=sk-proj-your-key-here
OCR_OPENAI_MODEL=gpt-4o-mini
